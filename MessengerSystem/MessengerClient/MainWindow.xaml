<Window x:Class="MessengerClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Messenger Client" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        
        <!-- Статус подключения -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="LightGray" Margin="0,0,0,5" Padding="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Статус: " FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"/>
                <TextBlock Text=" | " Margin="10,0,5,0"/>
                <TextBlock Text="Пользователь: " FontWeight="Bold"/>
                <TextBlock Text="{Binding UserId}"/>
                <Button Content="Отключиться" Command="{Binding DisconnectCommand}" Margin="20,0,0,0" Height="25"/>
            </StackPanel>
        </Border>
        
        <!-- Область чата -->
        <ListBox Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" ItemsSource="{Binding Messages}" Margin="0,0,5,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Список пользователей -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Margin="5,0,0,5">
            <ListBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="Green" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        
        <!-- Файловые передачи -->
        <Border Grid.Row="2" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Margin="5,5,0,5">
            <StackPanel>
                <TextBlock Text="Активные передачи" FontWeight="Bold" Margin="5"/>
                <ListBox ItemsSource="{Binding ActiveTransfers}" Height="100">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding FileName}" FontSize="10"/>
                                <ProgressBar Value="{Binding Progress}" Height="15" Margin="0,2"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
        
        <!-- Ввод сообщений -->
        <Grid Grid.Row="3" Grid.Column="0" Margin="0,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0" Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}" 
                     AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"
                     IsEnabled="{Binding IsConnected}"/>
            
            <Button Grid.Column="1" Content="Отправить" Command="{Binding SendMessageCommand}" 
                    Width="80" Margin="5,0" IsEnabled="{Binding IsConnected}"/>
            
            <Button Grid.Column="2" Content="Файл" Command="{Binding SendFileCommand}" 
                    Width="80" Margin="5,0" IsEnabled="{Binding IsConnected}"/>
        </Grid>
    </Grid>
</Window>