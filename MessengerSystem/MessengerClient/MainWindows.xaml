<Window x:Class="MessengerClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Messenger Client" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Верхняя панель статуса -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10" 
                Padding="10" Background="{Binding StatusColor}" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Статус: " FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding StatusText}" Foreground="White"/>
                <TextBlock Text=" | Пользователь: " FontWeight="Bold" Foreground="White" Margin="20,0,0,0"/>
                <TextBlock Text="{Binding UserId}" Foreground="White"/>
                
                <Button Content="Отключиться" Command="{Binding DisconnectCommand}"
                        Margin="20,0,0,0" Width="100" Background="White"/>
                <Button Content="⟳ Переподключиться" Command="{Binding ReconnectCommand}"
                        Margin="5,0,0,0" Width="120" Background="White"/>
            </StackPanel>
        </Border>
        
        <!-- Список сообщений -->
        <ListBox x:Name="MessagesListBox" Grid.Row="1" Grid.Column="0" 
                 ItemsSource="{Binding Messages}" Margin="0,0,10,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayText}" 
                               TextWrapping="Wrap"
                               Foreground="{Binding IsPrivate, 
                               Converter={StaticResource PrivateMessageColorConverter}}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Список пользователей -->
        <Border Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
            <ListBox ItemsSource="{Binding Users}" 
                     SelectedItem="{Binding SelectedUser}"
                     Background="Transparent"/>
        </Border>
        
        <!-- Активные передачи -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,5" 
                BorderBrush="LightGray" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Активные передачи" FontWeight="Bold" Margin="5"/>
                <ListBox ItemsSource="{Binding ActiveTransfers}" Height="60">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding FileName}" FontSize="11"/>
                                <ProgressBar Value="{Binding Progress}" Height="15"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
        
        <!-- Нижняя панель ввода -->
        <Grid Grid.Row="3" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0" Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsConnected}"
                     Margin="0,0,5,0"/>
            
            <Button Grid.Column="1" Content="Отправить" 
                    Command="{Binding SendMessageCommand}"
                    Width="80" Margin="0,0,5,0"/>
            
            <Button Grid.Column="2" Content="Файл" 
                    Command="{Binding SendFileCommand}"
                    Width="80"/>
        </Grid>
    </Grid>
</Window>